PORT=5000
NODE_ENV=development

# ⚠️  Replace this with your MongoDB Atlas connection string for production
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/blood-connect?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/blood-connect

JWT_SECRET=blood_connect_super_secret_jwt_key_2024
JWT_EXPIRE=7d

ADMIN_SIGNUP_KEY=sengodai-admin-secret

# Default admin account (auto-created on first start)
ADMIN_EMAIL=admin@sengodai.org
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User
ADMIN_PHONE=9876543210
ADMIN_LOCATION=Tirunelveli
ADMIN_BLOODGROUP=O+

# Default volunteer account (auto-created on first start)
DEFAULT_VOLUNTEER_EMAIL=esakkimuthu2907@gmail.com
DEFAULT_VOLUNTEER_PASSWORD=Esakki123

# Frontend URL - update with your actual Vercel frontend URL after deployment
FRONTEND_URL=http://localhost:5173

# Cloudinary (for image uploads - optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ENABLE_EMAIL_NOTIFICATIONS=false

ENABLE_UPLOADS=true
ENABLE_SOCKET_IO=true
ALLOW_IN_MEMORY=false
LOG_LEVEL=debug
