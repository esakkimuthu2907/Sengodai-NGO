# ==========================================
# MongoDB Connection Configuration
# ==========================================

# Option 1: MongoDB Atlas (Recommended for Production)
# Get this from MongoDB Atlas > Clusters > Connect > Drivers
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://bloodconnect:your_password@cluster0.xxxxx.mongodb.net/blood-connect?retryWrites=true&w=majority

# Option 2: Local MongoDB (Development)
# Requires MongoDB Community Server installed and running
# MONGO_URI=mongodb://localhost:27017/blood-connect

# Option 3: MongoDB Atlas Local (Recommended)
MONGO_URI=mongodb+srv://bloodconnect:your_password@cluster0.xxxxx.mongodb.net/blood-connect?retryWrites=true&w=majority

# ==========================================
# Server Configuration
# ==========================================
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ==========================================
# JWT Configuration
# ==========================================
# Generate a strong secret key: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_here_make_it_at_least_32_characters_long

# JWT Expiration time
JWT_EXPIRE=7d

# ==========================================
# Email Configuration (Optional - for contact forms)
# ==========================================
# Using Gmail, Yahoo, or any SMTP service

# Gmail: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=Blood Connect

# ==========================================
# Cloudinary Configuration (Optional - for image uploads)
# ==========================================
# Sign up at: https://cloudinary.com

CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# Admin Configuration
# ==========================================
# Default admin email (created on first server start if not exists)
ADMIN_EMAIL=admin@bloodconnect.org
ADMIN_PASSWORD=admin123

# ==========================================
# Security Configuration
# ==========================================
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window
AUTH_RATE_LIMIT_MAX=10       # Max login attempts per 15 mins

# ==========================================
# Feature Flags
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_UPLOADS=true
ENABLE_SOCKET_IO=true

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=debug  # debug, info, warn, error
